{
  "info": {
    "name": "BlockMyShow Backend",
    "description": "Postman collection for the current BlockMyShow backend auth APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "userEmail",
      "value": "user@example.com"
    },
    {
      "key": "userPassword",
      "value": "password123"
    },
    {
      "key": "userOtp",
      "value": "123456"
    },
    {
      "key": "userToken",
      "value": ""
    },
    {
      "key": "adminUsername",
      "value": "admin1"
    },
    {
      "key": "adminPassword",
      "value": "admin123"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "eventId",
      "value": "1"
    },
    {
      "key": "identityId",
      "value": "123456789012"
    },
    {
      "key": "phoneNumber",
      "value": "+919876543210"
    },
    {
      "key": "ticketOtp",
      "value": "123456"
    },
    {
      "key": "tokenId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            ""
          ]
        }
      }
    },
    {
      "name": "User Auth - Login Existing User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('userToken', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/user/auth",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "user",
            "auth"
          ]
        }
      }
    },
    {
      "name": "User Auth - Request Signup OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/user/auth",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "user",
            "auth"
          ]
        }
      }
    },
    {
      "name": "User Auth - Verify Signup OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('userToken', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"otp\": \"{{userOtp}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/user/auth",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "user",
            "auth"
          ]
        }
      }
    },
    {
      "name": "Admin Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('adminToken', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "login"
          ]
        }
      }
    },
    {
      "name": "Events - Get All",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/events",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "events"
          ]
        }
      }
    },
    {
      "name": "Events - Get One",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/events/{{eventId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "events",
            "{{eventId}}"
          ]
        }
      }
    },
    {
      "name": "Events - Create Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.event && json.event.$id) pm.collectionVariables.set('eventId', json.event.$id);"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"BlockMyShow Launch Night\",\n  \"venue\": \"Kolkata\",\n  \"date\": \"2026-06-01T18:00:00.000Z\",\n  \"price\": 499,\n  \"totalTickets\": 100,\n  \"metadataURI\": \"ipfs://event-metadata\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/events",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "events"
          ]
        }
      }
    },
    {
      "name": "Events - Update Metadata Admin",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        },
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"metadataURI\": \"ipfs://updated-event-metadata\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/events/{{eventId}}/metadata",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "events",
            "{{eventId}}",
            "metadata"
          ]
        }
      }
    },
    {
      "name": "Identity - Add Identity",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identity_id\": \"{{identityId}}\",\n  \"phone_number\": \"{{phoneNumber}}\",\n  \"name\": \"John Doe\",\n  \"profile_photo_url\": \"https://example.com/photo.jpg\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/identity/add",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "identity",
            "add"
          ]
        }
      }
    },
    {
      "name": "Tickets - Request Ticket",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.expires_in_minutes) console.log('OTP expires in: ' + json.expires_in_minutes + ' minutes');"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{userToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event_id\": {{eventId}},\n  \"identity_id\": \"{{identityId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tickets/request",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tickets",
            "request"
          ]
        }
      }
    },
    {
      "name": "Tickets - Confirm Ticket",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.token_id) pm.collectionVariables.set('tokenId', json.token_id);"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{userToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event_id\": {{eventId}},\n  \"identity_id\": \"{{identityId}}\",\n  \"otp\": \"{{ticketOtp}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tickets/confirm",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tickets",
            "confirm"
          ]
        }
      }
    },
    {
      "name": "Tickets - Get My Tickets",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{userToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tickets/my-tickets",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tickets",
            "my-tickets"
          ]
        }
      }
    },
    {
      "name": "Gate - Entry Verification",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.message) console.log('Gate Entry: ' + json.message);"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token_id\": {{tokenId}},\n  \"identity_id\": \"{{identityId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/gate/entry",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "gate",
            "entry"
          ]
        }
      }
    },
    {
      "name": "Gate - Verify Entry",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
