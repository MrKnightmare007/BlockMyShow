{
  "info": {
    "name": "BlockMyShow Backend",
    "description": "Postman collection for BlockMyShow backend APIs organized by feature",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:5000"},
    {"key": "userEmail", "value": "user@example.com"},
    {"key": "userPassword", "value": "password123"},
    {"key": "userOtp", "value": "123456"},
    {"key": "userToken", "value": ""},
    {"key": "adminUsername", "value": "admin1"},
    {"key": "adminPassword", "value": "admin123"},
    {"key": "adminToken", "value": ""},
    {"key": "eventId", "value": "1"},
    {"key": "identityId", "value": "123456789012"},
    {"key": "phoneNumber", "value": "+919876543210"},
    {"key": "ticketOtp", "value": "123456"},
    {"key": "tokenId", "value": "1"},
    {"key": "contractAddress", "value": "0xD1c02b3F300CC5815A84E0c5cB36C179FB673A0F"},
    {"key": "listPrice", "value": "500"},
    {"key": "buyerIdentity", "value": "buyer123"},
    {"key": "resaleOtp", "value": "123456"}
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {"raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""]}
      }
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "User Auth - Login Existing User",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.token) pm.collectionVariables.set('userToken', json.token);"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\": \"{{userEmail}}\", \"password\": \"{{userPassword}}\"}"},
            "url": {"raw": "{{baseUrl}}/api/user/auth", "host": ["{{baseUrl}}"], "path": ["api", "user", "auth"]}
          }
        },
        {
          "name": "User Auth - Request Signup OTP",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\": \"{{userEmail}}\", \"password\": \"{{userPassword}}\"}"},
            "url": {"raw": "{{baseUrl}}/api/user/auth", "host": ["{{baseUrl}}"], "path": ["api", "user", "auth"]}
          }
        },
        {
          "name": "User Auth - Verify Signup OTP",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.token) pm.collectionVariables.set('userToken', json.token);"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\": \"{{userEmail}}\", \"password\": \"{{userPassword}}\", \"otp\": \"{{userOtp}}\"}"},
            "url": {"raw": "{{baseUrl}}/api/user/auth", "host": ["{{baseUrl}}"], "path": ["api", "user", "auth"]}
          }
        },
        {
          "name": "Admin Login",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.token) pm.collectionVariables.set('adminToken', json.token);"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"username\": \"{{adminUsername}}\", \"password\": \"{{adminPassword}}\"}"},
            "url": {"raw": "{{baseUrl}}/api/admin/login", "host": ["{{baseUrl}}"], "path": ["api", "admin", "login"]}
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/events", "host": ["{{baseUrl}}"], "path": ["api", "events"]}
          }
        },
        {
          "name": "Get Event by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}"]}
          }
        },
        {
          "name": "Create Event",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.event && json.event.eventId) pm.collectionVariables.set('eventId', json.event.eventId);"]}}],
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{adminToken}}", "type": "string"}]},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"title\": \"BlockMyShow Launch Night\", \"venue\": \"Kolkata\", \"date\": \"2026-06-01T18:00:00.000Z\", \"price\": 499, \"totalTickets\": 100, \"photoUrl\": \"https://example.com/poster.jpg\"}"},
            "url": {"raw": "{{baseUrl}}/api/events", "host": ["{{baseUrl}}"], "path": ["api", "events"]}
          }
        },
        {
          "name": "Update Event Metadata",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{adminToken}}", "type": "string"}]},
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"photoUrl\": \"https://example.com/updated-poster.jpg\"}"},
            "url": {"raw": "{{baseUrl}}/api/events/{{eventId}}/metadata", "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}", "metadata"]}
          }
        }
      ]
    },
    {
      "name": "Identity",
      "item": [
        {
          "name": "Add Identity",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"identity_id\": \"{{identityId}}\", \"phone_number\": \"{{phoneNumber}}\", \"name\": \"John Doe\", \"profile_photo_url\": \"https://example.com/photo.jpg\"}"},
            "url": {"raw": "{{baseUrl}}/api/identity/add", "host": ["{{baseUrl}}"], "path": ["api", "identity", "add"]}
          }
        }
      ]
    },
    {
      "name": "Tickets - Purchase",
      "item": [
        {
          "name": "Request Ticket",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.expires_in_minutes) console.log('OTP expires in: ' + json.expires_in_minutes + ' minutes');"]}}],
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{userToken}}", "type": "string"}]},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"event_id\": {{eventId}}, \"identity_id\": \"{{identityId}}\"}"},
            "url": {"raw": "{{baseUrl}}/api/tickets/request", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "request"]}
          }
        },
        {
          "name": "Confirm Ticket",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.token_id) pm.collectionVariables.set('tokenId', json.token_id);"]}}],
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{userToken}}", "type": "string"}]},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"event_id\": {{eventId}}, \"identity_id\": \"{{identityId}}\", \"otp\": \"{{ticketOtp}}\"}"},
            "url": {"raw": "{{baseUrl}}/api/tickets/confirm", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "confirm"]}
          }
        },
        {
          "name": "Get My Tickets",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{userToken}}", "type": "string"}]},
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/tickets/my-tickets", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "my-tickets"]}
          }
        },
        {
          "name": "Get Ticket Details",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{userToken}}", "type": "string"}]},
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/tickets/{{tokenId}}", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "{{tokenId}}"]}
          }
        }
      ]
    },
    {
      "name": "Tickets - Resale",
      "item": [
        {
          "name": "List for Resale",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{userToken}}"}],
            "body": {"mode": "raw", "raw": "{\"tokenId\": \"{{tokenId}}\", \"price\": \"{{listPrice}}\"}"},
            "url": {"raw": "{{baseUrl}}/api/tickets/list", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "list"]}
          }
        },
        {
          "name": "Update List Price",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{userToken}}"}],
            "body": {"mode": "raw", "raw": "{\"tokenId\": \"{{tokenId}}\", \"newPrice\": \"600\"}"},
            "url": {"raw": "{{baseUrl}}/api/tickets/update-list-price", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "update-list-price"]}
          }
        },
        {
          "name": "Cancel Listing",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{userToken}}"}],
            "body": {"mode": "raw", "raw": "{\"tokenId\": \"{{tokenId}}\"}"},
            "url": {"raw": "{{baseUrl}}/api/tickets/cancel-listing", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "cancel-listing"]}
          }
        },
        {
          "name": "Get Marketplace",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/tickets/marketplace", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "marketplace"]}
          }
        },
        {
          "name": "Buy Resale - Request OTP",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.data && json.data.otpSent) {", "  pm.collectionVariables.set('resaleOtp', '123456');", "}"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{userToken}}"}],
            "body": {"mode": "raw", "raw": "{\"tokenId\": \"{{tokenId}}\", \"buyerIdentity\": \"{{buyerIdentity}}\"}"},
            "url": {"raw": "{{baseUrl}}/api/tickets/buy-resale/request", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "buy-resale", "request"]}
          }
        },
        {
          "name": "Buy Resale - Confirm with OTP",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{userToken}}"}],
            "body": {"mode": "raw", "raw": "{\"tokenId\": \"{{tokenId}}\", \"buyerIdentity\": \"{{buyerIdentity}}\", \"otp\": \"{{resaleOtp}}\"}"},
            "url": {"raw": "{{baseUrl}}/api/tickets/buy-resale/confirm", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "buy-resale", "confirm"]}
          }
        }
      ]
    },
    {
      "name": "Gate",
      "item": [
        {
          "name": "Entry Verification",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.message) console.log('Gate Entry: ' + json.message);"]}}],
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{adminToken}}", "type": "string"}]},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"token_id\": {{tokenId}}, \"identity_id\": \"{{identityId}}\"}"},
            "url": {"raw": "{{baseUrl}}/api/gate/entry", "host": ["{{baseUrl}}"], "path": ["api", "gate", "entry"]}
          }
        },
        {
          "name": "Verify Entry",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{adminToken}}", "type": "string"}]},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"token_id\": {{tokenId}}, \"identity_id\": \"{{identityId}}\", \"otp\": \"{{ticketOtp}}\"}"},
            "url": {"raw": "{{baseUrl}}/api/gate/verify-entry", "host": ["{{baseUrl}}"], "path": ["api", "gate", "verify-entry"]}
          }
        }
      ]
    }
  ]
}
