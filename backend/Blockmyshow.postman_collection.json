{
  "info": {
    "name": "BlockMyShow Backend",
    "description": "Postman collection for the current BlockMyShow backend auth APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "userEmail",
      "value": "user@example.com"
    },
    {
      "key": "userPassword",
      "value": "password123"
    },
    {
      "key": "userOtp",
      "value": "123456"
    },
    {
      "key": "userToken",
      "value": ""
    },
    {
      "key": "adminEmail",
      "value": "admin@example.com"
    },
    {
      "key": "adminPassword",
      "value": "admin123"
    },
    {
      "key": "adminToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            ""
          ]
        }
      }
    },
    {
      "name": "User Auth - Login Existing User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('userToken', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/user/auth",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "user",
            "auth"
          ]
        }
      }
    },
    {
      "name": "User Auth - Request Signup OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/user/auth",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "user",
            "auth"
          ]
        }
      }
    },
    {
      "name": "User Auth - Verify Signup OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('userToken', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"otp\": \"{{userOtp}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/user/auth",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "user",
            "auth"
          ]
        }
      }
    },
    {
      "name": "Admin Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('adminToken', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "login"
          ]
        }
      }
    }
  ]
}
