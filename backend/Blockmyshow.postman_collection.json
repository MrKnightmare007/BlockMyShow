{
  "info": {
    "name": "BlockMyShow Backend",
    "description": "Postman collection for the current BlockMyShow backend auth APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "userEmail",
      "value": "user@example.com"
    },
    {
      "key": "userPassword",
      "value": "password123"
    },
    {
      "key": "userOtp",
      "value": "123456"
    },
    {
      "key": "userToken",
      "value": ""
    },
    {
      "key": "adminUsername",
      "value": "admin1"
    },
    {
      "key": "adminPassword",
      "value": "admin123"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "eventId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            ""
          ]
        }
      }
    },
    {
      "name": "User Auth - Login Existing User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('userToken', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/user/auth",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "user",
            "auth"
          ]
        }
      }
    },
    {
      "name": "User Auth - Request Signup OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/user/auth",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "user",
            "auth"
          ]
        }
      }
    },
    {
      "name": "User Auth - Verify Signup OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('userToken', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"otp\": \"{{userOtp}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/user/auth",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "user",
            "auth"
          ]
        }
      }
    },
    {
      "name": "Admin Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('adminToken', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "login"
          ]
        }
      }
    },
    {
      "name": "Events - Get All",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/events",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "events"
          ]
        }
      }
    },
    {
      "name": "Events - Get One",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/events/{{eventId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "events",
            "{{eventId}}"
          ]
        }
      }
    },
    {
      "name": "Events - Create Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.event && json.event.$id) pm.collectionVariables.set('eventId', json.event.$id);"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"BlockMyShow Launch Night\",\n  \"venue\": \"Kolkata\",\n  \"date\": \"2026-06-01T18:00:00.000Z\",\n  \"price\": 499,\n  \"totalTickets\": 100,\n  \"metadataURI\": \"ipfs://event-metadata\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/events",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "events"
          ]
        }
      }
    },
    {
      "name": "Events - Update Metadata Admin",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        },
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"metadataURI\": \"ipfs://updated-event-metadata\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/events/{{eventId}}/metadata",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "events",
            "{{eventId}}",
            "metadata"
          ]
        }
      }
    }
  ]
}
