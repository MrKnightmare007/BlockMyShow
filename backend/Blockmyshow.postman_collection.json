        "body": {
          "mode": "raw",
          "raw": "{\n  \"token_id\": {{tokenId}},\n  \"identity_id\": \"{{identityId}}\",\n  \"otp\": \"{{ticketOtp}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/gate/verify-entry",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "gate",
            "verify-entry"
          ]
        }
      }
    }
  ]
}
