# Environment Variables for ProofPass Backend

# Server Configuration
PORT=5000
NODE_ENV=development

# Database - Firebase Firestore
DATABASE_URL=firestore://proofpass-27725
FIREBASE_PROJECT_ID=proofpass-27725
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY=your_private_key_here
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@proofpass-27725.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_CERT_URL=your_cert_url

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Smart Contract - Base Sepolia Testnet
NETWORK_URL=https://sepolia.base.org
CONTRACT_ADDRESS=0x816EcFD04b8110D7Dc3b6AB0e056C2e1435F5812
NETWORK_NAME=base-sepolia
CHAIN_ID=84532
CONTRACT_OWNER_PRIVATE_KEY=

# Razorpay Payment
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# IPFS
IPFS_API_URL=https://api.pinata.cloud
IPFS_JWT_TOKEN=

# Email Service (for OTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Third-party Services
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
